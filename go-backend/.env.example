APP_NAME=GraphInsight Go API
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8081
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
# env | admin | auto. admin/auto read /api/v1/admin/config/neo4j/all from Python.
NEO4J_CONFIG_SOURCE=env
# Required for NEO4J_CONFIG_SOURCE=admin or auto when reading admin config.
GO_ADMIN_CONFIG_TOKEN=

PYTHON_BACKEND_BASE_URL=http://127.0.0.1:8001
PYTHON_BACKEND_TIMEOUT_SECONDS=60
PYTHON_BACKEND_FORWARD_AUTH=true
ORCHESTRATOR_RETRY_MAX=2
ORCHESTRATOR_RETRY_BACKOFF_MS=200
ORCHESTRATOR_RETRY_MAX_BACKOFF_MS=1500
ORCHESTRATOR_SAFE_RETRY_DOCQA=false
IDEMPOTENCY_CACHE_TTL_SECONDS=600
RBAC_ENFORCE_BUSINESS_API=true
