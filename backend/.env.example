# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_CONNECTION_TIMEOUT_SECONDS=5
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_SECONDS=5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001

# Media Storage
MEDIA_STORAGE_PATH=./media
# Document Storage
DOCUMENT_STORAGE_PATH=./documents

# LLM Entity Extraction (OpenAI compatible)
LLM_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_MAX_ENTITIES=12
LLM_TEMPERATURE=0.1
LLM_QA_MODEL=
LLM_QA_TEMPERATURE=0.2
LLM_QA_MAX_TOKENS=600
LLM_QA_MAX_CONTEXT=4
HTTP_CLIENT_TRUST_ENV=false

# OpenAI Configuration
OPENAI_BASE_URL=  # 可选，留空使用官方地址，或填入转发地址
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.1

# NL2Cypher Configuration
NL2CYPHER_ENABLED=true
NL2CYPHER_CACHE_SIZE=100
NL2CYPHER_MAX_LIMIT=100

# Unified backend mode
# Python exposes only /api/internal/* capability entrypoints for Go orchestration.
# Public business routes are owned by the Go gateway.
PUBLIC_BUSINESS_ROUTES_ENABLED=false

# Python public /api/v1/admin/* routes are retired in unified mode.
# POST /api/internal/jobs/wake remains available for Go -> Python worker nudge.
PUBLIC_ADMIN_ROUTES_ENABLED=false

# Admin System Configuration
ADMIN_DATABASE_URL=postgresql://graphinsight:graphinsight-dev-password@127.0.0.1:5434/graphinsight_admin
ADMIN_SECRET_KEY=your-secret-key-change-in-production

# RBAC Controls
RBAC_ENABLE=true
RBAC_ENFORCE_BUSINESS_API=true
# Go gateway authz mode: go_db | local_jwt_soft. Unified local development uses go_db.
# local_jwt is accepted as a compatibility alias for local_jwt_soft.
RBAC_AUTHZ_MODE=go_db
RBAC_FAIL_OPEN_WHEN_UNBOUND=false
RBAC_CACHE_TTL_SECONDS=60

# Jobs Runtime Controls
JOB_EXECUTION_TIMEOUT_SECONDS=600
JOB_HEARTBEAT_INTERVAL_SECONDS=10
JOB_AUTO_RETRY_ENABLED=true
JOB_AUTO_RETRY_BASE_DELAY_SECONDS=10
JOB_AUTO_RETRY_MAX_DELAY_SECONDS=300

# Alert Webhook (optional)
ALERT_WEBHOOK_URL=
ALERT_API_ERROR_RATE_THRESHOLD=0.05
ALERT_JOB_TIMEOUT_RATE_THRESHOLD=0.10
